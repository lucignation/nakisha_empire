generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentGateway {
  PAYSTACK
  FLUTTERWAVE
}

enum PromoDiscountType {
  PERCENTAGE
  FIXED
}

enum AdminRole {
  SUPER_ADMIN
}

model Product {
  id                String         @id @default(cuid())
  slug              String         @unique
  name              String
  shortDescription  String
  description       String
  category          String
  brand             String
  size              String
  price             Int
  salePrice         Int?
  promoStartsAt     DateTime?
  promoEndsAt       DateTime?
  rating            Float          @default(0)
  reviewCount       Int            @default(0)
  badge             String?
  emoji             String?
  accent            String?
  imageUrl          String
  cloudinaryPublicId String?
  galleryImages     Json?
  skinGoal          String
  collection        String
  highlights        Json
  ingredients       Json
  howToUse          String
  sku               String?        @unique
  isPublished       Boolean        @default(false)
  trackInventory    Boolean        @default(true)
  stockQuantity     Int            @default(0)
  isOutOfStock      Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  inventoryLogs     InventoryLog[]
  orderItems        OrderItem[]
  backInStockSubscriptions BackInStockSubscription[]

  @@index([isPublished, createdAt])
  @@index([category, brand])
}

model InventoryLog {
  id            String   @id @default(cuid())
  productId      String
  quantityBefore Int
  quantityAfter  Int
  changeAmount   Int
  reason         String
  createdAt      DateTime @default(now())
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
}

model Order {
  id               String         @id @default(cuid())
  orderNumber      String         @unique
  customerName     String
  customerEmail    String
  customerPhone    String?
  deliveryAddress  String         @default("")
  deliveryStateCode String        @default("")
  deliveryStateName String        @default("")
  status           OrderStatus    @default(PENDING)
  paymentGateway   PaymentGateway?
  paymentReference String?        @unique
  subtotalAmount   Int
  discountAmount   Int            @default(0)
  shippingAmount   Int
  totalAmount      Int
  promoCode        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  items            OrderItem[]

  @@index([customerEmail, createdAt])
  @@index([status, createdAt])
  @@index([deliveryStateCode, createdAt])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String?
  productName String
  quantity    Int
  unitPrice   Int
  totalPrice  Int
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
}

model AdminUser {
  id          String    @id @default(cuid())
  email       String    @unique
  passwordHash String
  role        AdminRole @default(SUPER_ADMIN)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([email, role])
}

model PromoCode {
  id             String            @id @default(cuid())
  code           String            @unique
  description    String?
  discountType   PromoDiscountType
  amount         Int
  minOrderAmount Int?
  startsAt       DateTime?
  endsAt         DateTime?
  isActive       Boolean           @default(true)
  usageLimit     Int?
  usageCount     Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([code, isActive])
}

model DeliveryRate {
  id         String   @id @default(cuid())
  stateCode  String   @unique
  stateName  String
  feeAmount  Int      @default(4500)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([stateName])
}

model BackInStockSubscription {
  id         String   @id @default(cuid())
  productId  String
  email      String
  createdAt  DateTime @default(now())
  notifiedAt DateTime?
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, email])
  @@index([productId, notifiedAt])
}
